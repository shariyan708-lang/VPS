# Telegram bot token from @BotFather.
BOT_TOKEN=1234567890:replace_with_your_bot_token

# Telegram numeric user IDs that can open /admin.
# Only these accounts will see and use the Telegram admin panel.
ADMIN_IDS=111111111,222222222

# Bot username without @. Used to generate referral links.
BOT_USERNAME=your_bot_username

# PostgreSQL connection string. Recommended for public/high-traffic VPS bots.
# Leave empty only for small local SQLite testing.
# Neon/PostgreSQL example: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Local SQLite database file. Used when DATABASE_URL is empty.
DB_PATH=data/telegram_selling_bot.sqlite3

# Performance tuning.
# Successful channel join checks are cached for this many seconds.
JOIN_CACHE_SECONDS=300
FAILED_JOIN_CACHE_SECONDS=20

# Settings are cached briefly to reduce database reads.
SETTINGS_CACHE_SECONDS=5
DB_SLOW_LOG_SECONDS=1.5
USER_TOUCH_SECONDS=60

# VPS performance/concurrency tuning.
UPDATE_WORKERS=16
MAX_PENDING_UPDATES=2000
BACKGROUND_WORKERS=4
ACTION_DEBOUNCE_SECONDS=0.7
ADMIN_ACTION_DEBOUNCE_SECONDS=0.35
SLOW_UPDATE_LOG_SECONDS=3
POLLING_ERROR_SLEEP_SECONDS=1
TG_API_TIMEOUT_SECONDS=8
TG_GET_UPDATES_TIMEOUT_SECONDS=20
TG_SEND_TIMEOUT_SECONDS=8
TG_EDIT_TIMEOUT_SECONDS=6
TG_COPY_TIMEOUT_SECONDS=10
TG_MEMBER_TIMEOUT_SECONDS=5
TG_DOCUMENT_TIMEOUT_SECONDS=25

# PostgreSQL/Neon connection stability.
# These keep PostgreSQL/Neon SSL connections alive and reconnect quickly if idle connections close.
PG_CONNECT_TIMEOUT=10
PG_KEEPALIVES_IDLE=30
PG_KEEPALIVES_INTERVAL=10
PG_KEEPALIVES_COUNT=5
PG_RECONNECT_LOG_SECONDS=60

# Telegram broadcast throttle. Keep a small delay to stay under Telegram limits.
BROADCAST_DELAY_SECONDS=0.025
